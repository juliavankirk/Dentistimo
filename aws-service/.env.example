# Dentistimo Backend Environment Variables
# These are used during SAM deployment

# AWS Region for deployment
AWS_REGION=us-east-1

# S3 bucket for Lambda deployment packages (create this bucket first)
# Example: my-dentistimo-deployment-bucket
DEPLOYMENT_BUCKET=

# Verified email address in SES for sending confirmation emails
# Must be verified in SES before use
FROM_EMAIL=

# Stack name for CloudFormation
STACK_NAME=dentistimo-stack
